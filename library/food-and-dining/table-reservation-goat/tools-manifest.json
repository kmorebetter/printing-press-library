{
  "api_name": "table-reservation-goat",
  "base_url": "https://www.opentable.com",
  "description": "One reservation CLI for OpenTable, Tock, and Resy — search all three networks at once, watch for cancellations",
  "mcp_ready": "full",
  "http_transport": "standard",
  "auth": {
    "type": "none"
  },
  "required_headers": [],
  "tools": [
    {
      "name": "availability_check",
      "description": "Check open slots for a restaurant on a specific date and party size. Required: restaurant. Optional: date, time, party (plus 3 more). Returns array of Slot.",
      "method": "GET",
      "path": "/availability",
      "no_auth": true,
      "params": [
        {
          "name": "restaurant",
          "type": "string",
          "location": "path",
          "description": "Restaurant slug (network-prefixed if ambiguous)",
          "required": true
        },
        {
          "name": "date",
          "type": "string",
          "location": "query",
          "description": "Date in YYYY-MM-DD; defaults to today"
        },
        {
          "name": "time",
          "type": "string",
          "location": "query",
          "description": "Time in HH:MM (24h); defaults to 19:00"
        },
        {
          "name": "party",
          "wire_name": "party_size",
          "type": "int",
          "location": "query",
          "description": "Party size (default 2)"
        },
        {
          "name": "forward_minutes",
          "type": "int",
          "location": "query",
          "description": "Search +/- N minutes around requested time (default 150)"
        },
        {
          "name": "forward_days",
          "type": "int",
          "location": "query",
          "description": "Also search forward N days (default 0; same-day only)"
        },
        {
          "name": "attribute",
          "type": "string",
          "location": "query",
          "description": "Filter by slot attribute (patio, bar, highTop, standard, experience)"
        }
      ]
    },
    {
      "name": "availability_multi_day",
      "description": "Multi-day availability for a single restaurant — Mon-Sun matrix. Required: restaurant, start_date. Optional: days, party. Returns array of SlotDay.",
      "method": "GET",
      "path": "/availability/multi-day",
      "no_auth": true,
      "params": [
        {
          "name": "restaurant",
          "type": "string",
          "location": "path",
          "description": "Restaurant slug",
          "required": true
        },
        {
          "name": "start_date",
          "type": "string",
          "location": "query",
          "description": "Start of date range (YYYY-MM-DD)",
          "required": true
        },
        {
          "name": "days",
          "type": "int",
          "location": "query",
          "description": "Number of days to scan (default 7, max 14)"
        },
        {
          "name": "party",
          "wire_name": "party_size",
          "type": "int",
          "location": "query",
          "description": "Party size (default 2)"
        }
      ]
    },
    {
      "name": "experiences_get",
      "description": "Get a single experience's detail. Required: id. Returns the Experience.",
      "method": "GET",
      "path": "/experiences/{id}",
      "no_auth": true,
      "params": [
        {
          "name": "id",
          "type": "string",
          "location": "path",
          "description": "Experience ID (network-prefixed)",
          "required": true
        }
      ]
    },
    {
      "name": "experiences_list",
      "description": "List experiences (PRIX_FIXE, EXPERIENCE, PACKAGE) across OpenTable + Tock. Optional: restaurant, type, cuisine (plus 1 more). Returns array of Experience.",
      "method": "GET",
      "path": "/experiences",
      "no_auth": true,
      "params": [
        {
          "name": "restaurant",
          "type": "string",
          "location": "query",
          "description": "Filter to a single restaurant slug"
        },
        {
          "name": "type",
          "type": "string",
          "location": "query",
          "description": "Experience type (prix_fixe, experience, package)"
        },
        {
          "name": "cuisine",
          "type": "string",
          "location": "query",
          "description": "Cuisine filter"
        },
        {
          "name": "max_price_cents",
          "type": "int",
          "location": "query",
          "description": "Maximum price per person (in cents)"
        }
      ]
    },
    {
      "name": "me_get",
      "description": "Show your OpenTable and Tock profile (email, phone, points balance) — requires auth login. Returns the Profile.",
      "method": "GET",
      "path": "/me",
      "no_auth": true,
      "params": []
    },
    {
      "name": "reservations_book",
      "description": "Make a reservation. Print-by-default; requires --launch to actually fire the booking POST. Required: restaurant, slot_token, party_size. Optional: first_name, last_name, phone (plus 2 more). Returns the new Reservation.",
      "method": "POST",
      "path": "/reservations",
      "no_auth": true,
      "params": [
        {
          "name": "restaurant",
          "type": "string",
          "location": "body",
          "description": "Restaurant slug",
          "required": true
        },
        {
          "name": "slot_token",
          "type": "string",
          "location": "body",
          "description": "Slot token from a recent availability call",
          "required": true
        },
        {
          "name": "party_size",
          "type": "int",
          "location": "body",
          "required": true
        },
        {
          "name": "first_name",
          "type": "string",
          "location": "body"
        },
        {
          "name": "last_name",
          "type": "string",
          "location": "body"
        },
        {
          "name": "phone",
          "type": "string",
          "location": "body"
        },
        {
          "name": "email",
          "type": "string",
          "location": "body"
        },
        {
          "name": "special_requests",
          "type": "string",
          "location": "body"
        }
      ]
    },
    {
      "name": "reservations_cancel",
      "description": "Cancel a reservation. Requires --confirm. Required: id. Returns the Reservation. Destructive.",
      "method": "DELETE",
      "path": "/reservations/{id}",
      "no_auth": true,
      "params": [
        {
          "name": "id",
          "type": "string",
          "location": "path",
          "description": "Reservation ID",
          "required": true
        }
      ]
    },
    {
      "name": "reservations_get",
      "description": "Get a reservation's full detail. Required: id. Returns the Reservation.",
      "method": "GET",
      "path": "/reservations/{id}",
      "no_auth": true,
      "params": [
        {
          "name": "id",
          "type": "string",
          "location": "path",
          "description": "Reservation ID (network-prefixed)",
          "required": true
        }
      ]
    },
    {
      "name": "reservations_list",
      "description": "List your upcoming and past reservations across OpenTable + Tock + Resy. Optional: state, network, limit. Returns array of Reservation.",
      "method": "GET",
      "path": "/reservations",
      "no_auth": true,
      "params": [
        {
          "name": "state",
          "type": "string",
          "location": "query",
          "description": "Filter: upcoming, past, all (default upcoming)"
        },
        {
          "name": "network",
          "type": "string",
          "location": "query",
          "description": "Restrict to one network"
        },
        {
          "name": "limit",
          "type": "int",
          "location": "query",
          "description": "Max reservations to return"
        }
      ]
    },
    {
      "name": "restaurants_get",
      "description": "Get a restaurant's full detail — hours, address, cuisine, price band, photos, accolades. Required: slug. Returns the Restaurant.",
      "method": "GET",
      "path": "/restaurants/{slug}",
      "no_auth": true,
      "params": [
        {
          "name": "slug",
          "type": "string",
          "location": "path",
          "description": "Restaurant slug or 'opentable:\u003cslug\u003e' / 'tock:\u003cslug\u003e' for cross-network disambiguation",
          "required": true
        }
      ]
    },
    {
      "name": "restaurants_list",
      "description": "List restaurants across OpenTable, Tock, and Resy; filter by location, cuisine, price band, accolades, and party size. Optional: query, latitude, longitude (plus 8 more). Returns array of Restaurant.",
      "method": "GET",
      "path": "/restaurants",
      "no_auth": true,
      "params": [
        {
          "name": "query",
          "type": "string",
          "location": "query",
          "description": "Free-text query (matches name, cuisine, neighborhood)",
          "aliases": [
            "q"
          ]
        },
        {
          "name": "latitude",
          "type": "number",
          "location": "query",
          "description": "Latitude for geo search"
        },
        {
          "name": "longitude",
          "type": "number",
          "location": "query",
          "description": "Longitude for geo search"
        },
        {
          "name": "metro",
          "type": "string",
          "location": "query",
          "description": "Metro slug (e.g., chicago, seattle, new-york)"
        },
        {
          "name": "neighborhood",
          "type": "string",
          "location": "query",
          "description": "Neighborhood slug for geo-narrowed search"
        },
        {
          "name": "cuisine",
          "type": "string",
          "location": "query",
          "description": "Cuisine filter (e.g., italian, japanese, tasting-menu)"
        },
        {
          "name": "max-price",
          "wire_name": "price_band",
          "type": "int",
          "location": "query",
          "description": "Maximum price band 1-4"
        },
        {
          "name": "accolade",
          "type": "string",
          "location": "query",
          "description": "Filter by accolade (e.g., michelin, worlds50best)"
        },
        {
          "name": "party",
          "wire_name": "party_size",
          "type": "int",
          "location": "query",
          "description": "Party size for availability filter"
        },
        {
          "name": "network",
          "type": "string",
          "location": "query",
          "description": "Restrict to a network (opentable, tock); default queries both"
        },
        {
          "name": "limit",
          "type": "int",
          "location": "query",
          "description": "Max restaurants to return"
        }
      ]
    },
    {
      "name": "wishlist_list",
      "description": "List restaurants in your saved/wishlist (requires auth login). Optional: network. Returns array of Restaurant.",
      "method": "GET",
      "path": "/wishlist",
      "no_auth": true,
      "params": [
        {
          "name": "network",
          "type": "string",
          "location": "query",
          "description": "Restrict to one network"
        }
      ]
    }
  ]
}

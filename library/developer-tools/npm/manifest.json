{
  "manifest_version": "0.3",
  "name": "npm-pp-mcp",
  "display_name": "npm",
  "version": "4.24.0",
  "description": "Research npm packages by metadata, downloads, maintainers, freshness, and dependency risk.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {

{
  "manifest_version": "0.3",
  "name": "nylas-pp-mcp",
  "display_name": "Nylas",
  "version": "4.8.0",
  "description": "Nylas API surface as MCP tools.",
  "author": {
    "name": "CLI Printing Press"
  },
  "license": "Apache-2.0",
  "server": {
    "type": "binary",
    "entry_point": "bin/nylas-pp-mcp",
    "mcp_config": {
      "command": "${__dirname}/bin/nylas-pp-mcp",
      "args": [],
      "env": {
        "NYLAS_API_KEY": "${user_config.nylas_api_key}"
      }
    }
  },
  "user_config": {
    "nylas_api_key": {
      "type": "string",
      "title": "NYLAS_API_KEY",
      "description": "Sets NYLAS_API_KEY for the Nylas MCP server. Create a v3 application key at https://dashboard-v3.nylas.com (v3 API keys have the prefix nyk_v0_).",
      "sensitive": true,
      "required": true
    }
  },
  "compatibility": {
    "claude_desktop": ">=1.0.0",
    "platforms": [
      "darwin",
      "linux",
      "win32"
    ]
  }
}
